---
layout: null
permalink: /search.json
---
[
{% assign docs = site.pages | concat: site.posts %}
{% for collection in site.collections %}
  {% if collection.label != "posts" %}
    {% assign docs = docs | concat: collection.docs %}
  {% endif %}
{% endfor %}
{% assign docs = docs | sort: "url" %}
{% assign first_result = true %}
{% for doc in docs %}
  {% if doc.url and doc.url != "" and doc.url != "/404.html" and doc.search != false %}
  {% unless doc.url contains ".xml" or doc.url contains ".json" %}
  {% unless first_result %},{% endunless %}
  {% assign first_result = false %}
  {
    "title": {{ doc.title | default: doc.name | default: doc.url | jsonify }},
    "url": {{ doc.url | absolute_url | jsonify }},
    "content": {{ doc.content | markdownify | strip_html | normalize_whitespace | jsonify }}
  }
  {% endunless %}
  {% endif %}
{% endfor %}
]
